.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 临时文件
*.log
*.tmp
*.bak
.ipynb_checkpoints/

# Virtualenv / environment
venv/
ENV/
.env
.venv/
env/

# Testing / cache
.pytest_cache/
.mypy_cache/

# Model weights and large binaries
models/
*.h5

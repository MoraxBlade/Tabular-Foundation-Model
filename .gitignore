# Python
__pycache__/
*.py[cod]
*.pth
*.pt
*.pkl
*.egg-info/
dist/
build/

# 大文件（绝对禁止提交）
# 备份/压缩文件
*.csv.bak
*.zip
*.tar.gz
*.rar

# 原始数据不入库，仅保留下载链接
data/raw/*
!data/raw/download_links.txt

# 处理后数据：仅允许提交<10MB的小型CSV，所有超大文件全部排除
# covtype预处理后会生成train/test两个文件，都要排除
data/processed/covtype*.csv
data/processed/*.zip
data/processed/*.tar.gz
data/processed/*.rar
data/processed/*.csv.bak

# 缺失值数据集同样排除超大文件
data/missing/covtype*.csv

# 系统文件
.DS_Store
Thumbs.db
*.swp
*.swo

